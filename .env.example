# Environment variables for Proyecto Radio Cesar Backend
# Copy this file to .env and fill in your values

# ============================================================
# Server Configuration
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# Database Configuration (Prisma ORM)
# Soporta: SQLite (desarrollo), MySQL, PostgreSQL (producción)
# ============================================================

# SQLITE (Development) - Recomendado para desarrollo local
# No requiere servidor, archivo local
DATABASE_URL=file:./data/dev.db

# MySQL (Production) - Descomentar para usar MySQL
# DATABASE_URL=mysql://user:password@localhost:3306/radio_cesar

# PostgreSQL (Production) - Descomentar para usar PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/radio_cesar

# ============================================================
# AzuraCast Integration
# ============================================================

# Production instance (MiRadioComunitaria)
AZURACAST_BASE_URL=https://radio-azura.orioncaribe.com
AZURACAST_STATION_ID=2
AZURACAST_API_KEY=

# Development (local AzuraCast instance - commented)
# AZURACAST_BASE_URL=http://localhost:88
# AZURACAST_STATION_ID=1

AZURACAST_POLLING_INTERVAL=15000

# ============================================================
# Authentication & Security
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# ============================================================
# CORS Configuration
# ============================================================
CORS_ORIGIN=http://localhost:8080

# ============================================================
# File Uploads
# ============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
