# Environment variables for Proyecto Radio Cesar Backend
# Copy this file to .env and fill in your values
# For Docker, use the root .env.docker file instead

# ============================================================
# Server Configuration
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# Database Configuration (Prisma ORM)
# Docker: postgresql://postgres:postgres@postgres:5432/radio_comunitaria
# Local: postgresql://user:password@localhost:5434/radio_comunitaria
# ============================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/radio_comunitaria

# ============================================================
# AzuraCast Integration
# ============================================================
AZURACAST_BASE_URL=https://radio-azura.orioncaribe.com
AZURACAST_STATION_ID=2
AZURACAST_API_KEY=your-api-key-here
AZURACAST_POLLING_INTERVAL=15000

# ============================================================
# Authentication & Security
# ============================================================
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRATION=7d

# ============================================================
# CORS Configuration
# ============================================================
CORS_ORIGIN=http://localhost:3006

# ============================================================
# File Uploads
# ============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
